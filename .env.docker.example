# Docker Environment Variables
# Copy these values to your Portainer container settings or docker-compose .env file

TRUENAS_HOST=192.168.1.100
TRUENAS_API_KEY=your-api-key-here
DISCORD_WEBHOOK=https://discord.com/api/webhooks/XXXXXX/XXXXXXXX
NODE_TLS_REJECT_UNAUTHORIZED=0
CHECK_INTERVAL_MS=60000
RUNNING_UPDATE_INTERVAL_MS=300000
RECONNECT_DELAY_MS=5000
KEEPALIVE_INTERVAL_MS=30000

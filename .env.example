TRUENAS_HOST=127.0.0.1 # ip address of your TrueNAS server
TRUENAS_API_KEY=XXXXXXXXXXXXXXXXXXXXXX # API key for your TrueNAS server, can be generated in the web interface under "API Keys"
DISCORD_WEBHOOK=https://discord.com/api/webhooks/XXXXXXXXXXXXXXXXXXXXXX/XXXXXXXXXXXXXXXX # Discord webhook URL, can be generated in your Discord server settings under "Integrations" -> "Webhooks"
NODE_TLS_REJECT_UNAUTHORIZED=0 # mandatory for self-signed certificates, set to 1 if you have a valid certificate on your TrueNAS server